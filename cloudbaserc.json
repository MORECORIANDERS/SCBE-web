{
  "envId": "python12-9guk780v324f024d",
  "functionRoot": "cloudfunctions",
  "functions": [
    {
      "name": "cb_snapshot_updater",
      "timeout": 120,
      "memorySize": 256,
      "runtime": "Nodejs18.15"
    },
    {
      "name": "cb_oversold_detector",
      "timeout": 120,
      "memorySize": 256,
      "runtime": "Nodejs18.15"
    },
    {
      "name": "cb_oversold_detector_weekly",
      "timeout": 300,
      "memorySize": 512,
      "runtime": "Nodejs20.19",
      "handler": "index.main",
      "description": "可转债周线超卖检测云函数，每天15:40触发"
    },
    {
      "name": "cb_weekly_kline_mootdx",
      "timeout": 600,
      "memorySize": 512,
      "runtime": "Python3.10",
      "layers": [
        {
          "name": "mootdx310",
          "version": 1
        }
      ]
    },
    {
      "name": "cb_volume_filter",
      "timeout": 300,
      "memorySize": 512,
      "runtime": "Python3.10",
      "layers": [
        {
          "name": "pymysql",
          "version": 3
        }
      ]
    },
    {
      "name": "cb_weekly_kline_aggregator",
      "timeout": 300,
      "memorySize": 256,
      "runtime": "Nodejs20.19",
      "handler": "index.main",
      "description": "可转债周线聚合云函数，每天15:36触发"
    },
    {
      "name": "cb_weekly_kline_init",
      "timeout": 600,
      "memorySize": 512,
      "runtime": "Nodejs20.19",
      "handler": "index.main",
      "description": "可转债周线数据初始化函数，仅需运行一次"
    },
    {
      "name": "api-bridge",
      "timeout": 180,
      "memorySize": 256,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "description": "HTTP API bridge for GitHub Pages frontend"
    }
  ]
}
